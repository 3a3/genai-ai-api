{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "openAiLocation": {
      "value": "eastus2"
    },
    "openAiChatModelName": {
      "value": "gpt-5.4-mini"
    },
    "openAiChatModelVersion": {
      "value": "2026-03-17"
    },
    "openAiChatDeploymentSku": {
      "value": "GlobalStandard"
    },
    "openAiChatDeploymentCapacity": {
      "value": 50
    },
    "openAiEmbeddingModelName": {
      "value": "text-embedding-3-small"
    },
    "openAiEmbeddingModelVersion": {
      "value": "1"
    },
    "openAiEmbeddingDeploymentSku": {
      "value": "Standard"
    },
    "openAiEmbeddingDeploymentCapacity": {
      "value": 50
    },
    "searchSku": {
      "value": "basic"
    },
    "apimSku": {
      "value": "Consumption"
    },
    "apimPublisherEmail": {
      "value": "admin@example.com"
    },
    "apimPublisherName": {
      "value": "Query Expansion RAG"
    },
    "apiAllowedSourceIpsCsv": {
      "value": "${AZURE_API_ALLOWED_SOURCE_IPS=}"
    }
  }
}
